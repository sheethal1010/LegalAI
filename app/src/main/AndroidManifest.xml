<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".LegalAiApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.LegalAI"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false">

        <!-- Splash -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.LegalAI.Splash"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding -->
        <activity android:name=".activities.OnboardingActivity"
            android:exported="false" />

        <!-- Auth -->
        <activity android:name=".activities.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".activities.SignupActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".activities.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main -->
        <activity android:name=".activities.MainActivity"
            android:exported="false" />

        <!-- Feature screens -->
        <activity android:name=".activities.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".activities.LawyerProfileActivity"
            android:exported="false" />
        <activity android:name=".activities.CaseTrackingActivity"
            android:exported="false" />
        <activity android:name=".activities.EditProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".activities.LegalGlossaryActivity"
            android:exported="false" />
        <activity android:name=".activities.NotificationsActivity"
            android:exported="false" />
        <activity android:name=".activities.SavedLawyersActivity"
            android:exported="false" />
        <activity android:name=".activities.SearchResultsActivity"
            android:exported="false" />
        <activity android:name=".activities.AgentMarketplaceActivity"
            android:exported="false" />
        <activity android:name=".activities.DocumentUploadActivity"
            android:exported="false" />

        <!-- FCM -->
        <service
            android:name=".utils.LegalAiFcmService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>
</manifest>
