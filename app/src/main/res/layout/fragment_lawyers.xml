<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/light_bg_page">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/midnight_navy" android:orientation="vertical" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="20dp" android:paddingBottom="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Find a Lawyer" android:textColor="@android:color/white" android:textSize="24sp" android:textStyle="bold"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Expert legal counsel at your fingertips" android:textColor="@color/counsel_gold" android:textSize="13sp" android:layout_marginTop="2dp" android:layout_marginBottom="16dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_search" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="14dp" android:paddingEnd="14dp">
      <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_search" app:tint="@color/light_text_muted"/>
      <EditText android:id="@+id/et_search_lawyers" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="Search by name or specialty…" android:hintTextColor="@color/light_text_muted" android:background="@android:color/transparent" android:inputType="text" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="10dp"/>
    </LinearLayout>
  </LinearLayout>
  <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_lawyers" android:layout_width="match_parent" android:layout_height="match_parent" android:clipToPadding="false" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="80dp"/>
</LinearLayout>