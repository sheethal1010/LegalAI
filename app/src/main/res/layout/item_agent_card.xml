<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/card_agent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="2dp" app:cardBackgroundColor="@android:color/white">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
      <LinearLayout android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_agent_icon" android:gravity="center">
        <TextView android:id="@+id/tv_agent_emoji" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚖️" android:textSize="24sp"/>
      </LinearLayout>
      <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
        <TextView android:id="@+id/tv_agent_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Agent Title" android:textColor="@color/light_text_heading" android:textSize="15sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
        <TextView android:id="@+id/tv_agent_category" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_gold_rounded_sm" android:text="Contract" android:textColor="@color/midnight_navy" android:textSize="10sp" android:textStyle="bold" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="3dp" android:paddingBottom="3dp" android:layout_marginTop="4dp"/>
      </LinearLayout>
      <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
        <ImageView android:layout_width="13dp" android:layout_height="13dp" android:src="@drawable/ic_star" app:tint="@color/counsel_gold"/>
        <TextView android:id="@+id/tv_agent_rating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4.9" android:textColor="@color/light_text_heading" android:textSize="12sp" android:textStyle="bold" android:layout_marginStart="3dp"/>
      </LinearLayout>
    </LinearLayout>
    <TextView android:id="@+id/tv_agent_description" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Agent description" android:textColor="@color/light_text_muted" android:textSize="13sp" android:lineSpacingExtra="3dp" android:maxLines="2" android:ellipsize="end" android:layout_marginTop="12dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="12dp">
      <TextView android:id="@+id/tv_agent_usage" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="2.4k uses" android:textColor="@color/light_text_muted" android:textSize="12sp"/>
      <com.google.android.material.button.MaterialButton android:id="@+id/btn_use_agent" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Use Agent" android:textSize="12sp" android:backgroundTint="@color/midnight_navy" android:textColor="@android:color/white" android:paddingStart="16dp" android:paddingEnd="16dp"/>
    </LinearLayout>
  </LinearLayout>
</com.google.android.material.card.MaterialCardView>