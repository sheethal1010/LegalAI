<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/light_bg_page">
  <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:background="@color/midnight_navy" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="4dp">
    <ImageView android:id="@+id/iv_back" android:layout_width="40dp" android:layout_height="40dp" android:padding="8dp" android:src="@drawable/ic_back" android:contentDescription="Back" app:tint="@android:color/white"/>
    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Case Tracking" android:textColor="@android:color/white" android:textSize="18sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
  </LinearLayout>
  <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@android:color/white" android:orientation="vertical" android:padding="20dp" android:layout_marginBottom="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
          <TextView android:id="@+id/tv_case_title" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Case Title" android:textColor="@color/light_text_heading" android:textSize="18sp" android:textStyle="bold"/>
          <TextView android:id="@+id/tv_case_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_navy_rounded_sm" android:text="Criminal" android:textColor="@android:color/white" android:textSize="11sp" android:textStyle="bold" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_case_description" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Description" android:textColor="@color/light_text_heading" android:textSize="14sp" android:lineSpacingExtra="3dp" android:layout_marginTop="12dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Agent" android:textColor="@color/light_text_muted" android:textSize="11sp"/>
            <TextView android:id="@+id/tv_agent_used" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Contract Analyzer" android:textColor="@color/midnight_navy" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Assigned Lawyer" android:textColor="@color/light_text_muted" android:textSize="11sp"/>
            <TextView android:id="@+id/tv_assigned_lawyer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not assigned" android:textColor="@color/midnight_navy" android:textSize="13sp" android:textStyle="bold" android:layout_marginTop="2dp"/>
          </LinearLayout>
        </LinearLayout>
      </LinearLayout>
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@android:color/white" android:orientation="vertical" android:padding="24dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Case Progress" android:textColor="@color/light_text_heading" android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="20dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
          <View android:id="@+id/step_submitted" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_timeline_circle_done"/>
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Submitted" android:textColor="@color/light_text_heading" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Case received by Legal.AI" android:textColor="@color/light_text_muted" android:textSize="12sp"/>
          </LinearLayout>
        </LinearLayout>
        <View android:id="@+id/step_line_1" android:layout_width="2dp" android:layout_height="36dp" android:background="@color/counsel_gold" android:layout_marginStart="15dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
          <View android:id="@+id/step_ai" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_timeline_circle_pending"/>
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI Processing" android:textColor="@color/light_text_heading" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gemini AI analyzing your case" android:textColor="@color/light_text_muted" android:textSize="12sp"/>
          </LinearLayout>
        </LinearLayout>
        <View android:id="@+id/step_line_2" android:layout_width="2dp" android:layout_height="36dp" android:background="#CCCCCC" android:layout_marginStart="15dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
          <View android:id="@+id/step_review" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_timeline_circle_pending"/>
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lawyer Review" android:textColor="@color/light_text_heading" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Assigned advocate reviewing" android:textColor="@color/light_text_muted" android:textSize="12sp"/>
          </LinearLayout>
        </LinearLayout>
        <View android:id="@+id/step_line_3" android:layout_width="2dp" android:layout_height="36dp" android:background="#CCCCCC" android:layout_marginStart="15dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
          <View android:id="@+id/step_approved" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_timeline_circle_pending"/>
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Approved" android:textColor="@color/light_text_heading" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Legal advice approved" android:textColor="@color/light_text_muted" android:textSize="12sp"/>
          </LinearLayout>
        </LinearLayout>
        <View android:id="@+id/step_line_4" android:layout_width="2dp" android:layout_height="36dp" android:background="#CCCCCC" android:layout_marginStart="15dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
          <View android:id="@+id/step_delivered" android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_timeline_circle_pending"/>
          <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Delivered" android:textColor="@color/light_text_heading" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Final report delivered" android:textColor="@color/light_text_muted" android:textSize="12sp"/>
          </LinearLayout>
        </LinearLayout>
      </LinearLayout>
    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</LinearLayout>