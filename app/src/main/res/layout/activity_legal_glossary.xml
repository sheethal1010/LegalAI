<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/light_bg_page">
  <LinearLayout android:layout_width="match_parent" android:layout_height="64dp" android:background="@color/midnight_navy" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:elevation="4dp">
    <ImageView android:id="@+id/iv_back" android:layout_width="40dp" android:layout_height="40dp" android:padding="8dp" android:src="@drawable/ic_back" android:contentDescription="Back" app:tint="@android:color/white"/>
    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Legal Glossary" android:textColor="@android:color/white" android:textSize="18sp" android:textStyle="bold" android:layout_marginStart="8dp"/>
  </LinearLayout>
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/midnight_navy" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="16dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_search" android:gravity="center_vertical" android:orientation="horizontal" android:paddingStart="12dp" android:paddingEnd="12dp">
      <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_search" app:tint="@color/light_text_muted"/>
      <EditText android:id="@+id/et_search" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="Search legal terms…" android:hintTextColor="@color/light_text_muted" android:background="@android:color/transparent" android:inputType="text" android:textSize="14sp" android:textColor="@android:color/white" android:paddingStart="10dp"/>
    </LinearLayout>
  </LinearLayout>
  <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_glossary" android:layout_width="match_parent" android:layout_height="match_parent" android:clipToPadding="false" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="16dp"/>
</LinearLayout>